# Foundry authentication uses DefaultAzureCredential.
# Local dev: run `az login` and ensure your user principal has the
# `Azure AI Developer` role on the Foundry-SOW resource.
# Production: handled automatically by the ML Container App's managed identity.

AZURE_OPENAI_ENDPOINT=<foundry_project_url>
AZURE_OPENAI_DEPLOYMENT=Kimi-K2.5
AZURE_OPENAI_API_VERSION=2025-01-01-preview
